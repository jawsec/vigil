# vigil — home security monitor configuration
#
# Copy this file to config.yaml and edit with your settings:
#   cp config.yaml.example config.yaml
#
# At least one monitor must be enabled.

# --- Alert output ---
# Supported types: slack, matrix, json, stdout
# Use "json" or "stdout" for testing without a webhook.
alert:
  type: stdout
  # webhook_url: "https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# --- Monitors ---
monitors:

  # Crypto Wallet Watchdog
  # Monitors public wallet addresses for large outbound transfers
  # and transactions to flagged addresses.
  crypto:
    enabled: true
    # Free Etherscan API key (optional but recommended — faster rate limits)
    # Get one at: https://etherscan.io/myapikey
    etherscan_api_key: ""
    wallets:
      eth:
        - "0xde0B295669a9FD93d5F28D9Ec85E40f4cb697BAe"  # Ethereum Foundation (example)
      btc:
        - "1A1zP1eP5QGefi2DMPTfTL5SLmv7DivfNa"  # Satoshi's genesis address (example)
      # sol:
      #   - "YourSolanaAddressHere"  # Solana planned for v0.2
    thresholds:
      large_transfer_usd: 5000  # Alert on outbound transfers above this USD value
    # Optional: list of known-bad addresses to flag regardless of transfer size
    flagged_addresses: []

  # File Integrity Monitor
  # Watches directories for new, modified, or deleted files.
  # Catches persistence mechanisms (startup folder drops, extension tampering).
  file_integrity:
    enabled: true
    check_interval_seconds: 300  # How often to rescan (default: 5 minutes)
    watch_paths:
      - "defaults"  # Uses platform-appropriate default paths (recommended)
      # Or specify your own:
      # - "/home/youruser/.config/autostart"
      # - "/etc/cron.d"
      # - "C:\\Users\\YourUser\\AppData\\Roaming\\Microsoft\\Windows\\Start Menu\\Programs\\Startup"

  # Network Threat Feed Monitor (planned for v0.3)
  # network:
  #   enabled: false
